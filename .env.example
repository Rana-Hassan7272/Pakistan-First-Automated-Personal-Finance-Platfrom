# =========================
# Observability — LangSmith (tracing) + MLflow (experiments/metrics)
# =========================
# LangSmith: spans for RAG chain, Groq generation, and agent gateway/tool calls (see backend/rag/tracing.py).
# LANGCHAIN_TRACING_V2 must be the string "true" (not "tru").
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=finguard-agents
# Optional alias read by some LangChain builds:
# LANGSMITH_PROJECT=finguard-agents
#
# MLflow: ONE shared backend for all FinGuard ML + RAG eval — backend/ml/mlflow_tracking.py
# (default_tracking_uri → MLFLOW_TRACKING_URI or file backend/ml/mlruns). Do not run a separate UI/store for RAG only.
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# MLFLOW_FORCE_FILE_STORE=1

# =========================
# RAG (Phase 9)
# =========================
# Set to 1/true to force the legacy mock RAG (useful for CI without KB ingest).
FINGUARD_RAG_MOCK=0
# Embedding model (384-d MiniLM default). P9 §17 — LRU cache for repeated **query** embeddings (0=off, max 512).
# RAG_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RAG_EMBED_QUERY_CACHE_SIZE=0
# Optional: override Groq model for KB answers (default: llama-3.3-70b-versatile).
# RAG_GROQ_MODEL=
# P9 §17 — after primary Groq errors: smaller Groq (default = RAG_CP1_ROUTER_MODEL), then Gemini if GOOGLE_API_KEY or GEMINI_API_KEY.
# RAG_GROQ_MODEL_SMALL=llama-3.1-8b-instant
# RAG_GEMINI_FALLBACK_MODEL=gemini-2.0-flash
# RAG_LLM_FALLBACK_ENABLED=1
# Scanned PDFs: OCR fallback uses PaddleOCR (same as Phase 7). Tune if needed:
# RAG_PDF_OCR_FALLBACK=1
# RAG_OCR_PAGE_ZOOM=2.0
# RAG_OCR_LANG=en
# RAG_OCR_MERGED=0
# RAG_OCR_BACKEND: paddle | easyocr (default easyocr on Windows — Paddle 3.3 + oneDNN CPU often breaks).
# RAG_OCR_BACKEND=easyocr
# RAG_OCR_MAX_PAGES=0
# When Paddle finds no text, run EasyOCR on the same raster (default on).
# RAG_OCR_EASYOCR_ON_EMPTY=1
# When P9.3 is on, LangSmith traces RAG when LANGCHAIN_TRACING_V2=true (see Observability block above).
# RAG_P93_ENABLED=0 restores P9.2-only hybrid path (no CP1 / corrective / grounding loop).
# RAG_CP1_ROUTER_MODEL=llama-3.1-8b-instant
# RAG_CORRECTIVE_MODEL=llama-3.1-8b-instant
# RAG_CORRECTIVE_MAX_ROUNDS=3
# RAG_RELEVANCE_MIN_PARENT_DENSE=0.4
# RAG_MAX_PARENTS_AFTER_FILTER=5
# RAG_GROUNDING_MAX_REGENERATIONS=2
# P9.4 — prompt pack under configs/prompts/rag/<version>/ (default v1).
# RAG_PROMPT_VERSION=v1
# P9.5 — retrieval memory (topic → child_chunk boosts; 30-day decay via cron calling decay helper).
# RAG_RETRIEVAL_MEMORY_ENABLED=1
# RAG_MEMORY_SIMILARITY_BOOST=0.1
# RAG_MEMORY_FETCH_LIMIT=24
# RAG_MEMORY_READ_GLOBAL=1
# RAG_MEMORY_HIGH_CONF_MIN_CHUNKS=3
# RAG_MEMORY_HIGH_CONF_MIN_SIM=0.6
# RAG_MEMORY_MAX_WRITES_PER_QUERY=12
# RAG_MEMORY_DECAY_DAYS=30
# RAG_MEMORY_ANONYMOUS_WRITE=0
# P9.6 — user memory chunks (merge at query time when user_id is set; apply migration 20260515).
# RAG_USER_MEMORY_ENABLED=1
# RAG_USER_MEMORY_TOP_K=3
# RAG_USER_MEMORY_MAX_CHARS=2800
# Nightly ETL (Airflow rag_user_memory_nightly_dag): min debits in window to write a chunk; lookback days.
# RAG_USER_MEMORY_NIGHTLY_MIN_DEBITS=3
# RAG_USER_MEMORY_NIGHTLY_LOOKBACK_DAYS=30
# Personal spending queries (with user_id): max KB parent chunks; user memory block is ordered first.
# RAG_PERSONAL_SPENDING_KB_MAX_PARENTS=3
# RAG_PERSONAL_SPENDING_OMIT_KB=1
# P9.3 — web fallback when KB has no fused hits (DuckDuckGo by default; set RAG_WEB_PROVIDER=tavily + TAVILY_API_KEY for Tavily).
# RAG_WEB_FALLBACK_ENABLED=0
# RAG_WEB_MAX_RESULTS=2
# RAG_WEB_SNIPPET_CHARS=900
# RAG_WEB_PROVIDER=duckduckgo
# TAVILY_API_KEY=
# RAG_WEB_TRY_CP1_DIRECT — optional; when unset, defaults to same as RAG_WEB_FALLBACK_ENABLED (try web before CP1 direct reply).
# Set to 0 to keep only “empty KB hits → web” without CP1-direct web.
# RAG_WEB_TRY_CP1_DIRECT=0
# RAG_WEB_CP1_DIRECT_MIN_CHARS=10
# DuckDuckGo rate limits (HTTP 202): extra DDG attempts + delay; then Tavily if TAVILY_API_KEY is set.
# RAG_WEB_DDGS_EXTRA_TRIES=1
# RAG_WEB_DDGS_RETRY_DELAY_SEC=2.0
# RAG_WEB_TAVILY_ON_DDGS_EMPTY=1
# P9.7 — RAGAS / unified MLflow (logs via backend.ml.mlflow_tracking.log_rag_evaluation_summary).
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# RAG_EVAL_MLFLOW_EXPERIMENT=finguard_rag_phase9
# Eval JSONL (backend/rag/evaluation/ragas_questions.jsonl): optional per-row ``reference_contexts``
# (JSON array of strings) for NonLLM overlap / context recall; if omitted, ``ground_truth`` is used as one reference.
# For RAGAS Faithfulness (--ragas): set OPENAI_API_KEY (install langchain-openai) or GOOGLE_API_KEY (Gemini).
# RAGAS_OPENAI_MODEL=gpt-4o-mini
# RAGAS_GEMINI_MODEL=gemini-1.5-flash
# P9.8 — optional Locust load tests: pip install -r requirements-load.txt
#   locust -f backend/rag/evaluation/locustfile.py --host http://127.0.0.1:8000
#   Use FINGUARD_RAG_MOCK=1 on the API for offline soak; tune RAG_LOCUST_MESSAGE / RAG_LOCUST_USER_ID if needed.
# P9.8 — Celery rag.ingest_rag_corpus + Airflow rag_kb_ingest_manual_dag: default 1 = dry-run only (no DB/BM25 writes).
# RAG_INGEST_DRY_RUN=1
# Weekly RAGAS DAG: set RAGAS_INCLUDE_LLM=1 to append --ragas (needs evaluator keys on worker).
# RAGAS_INCLUDE_LLM=0

# =========================
# GPS merchant layer (Layer 2) — OSM free default, Google optional
# =========================
# No key required for OSM. Nearby shop lookup uses OpenStreetMap Overpass.
# OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
# OSM_GEO_ENABLED=true
# GEO_PLACES_PREFER=osm
# Optional fallback if OSM misses (requires Google Cloud billing account):
# GOOGLE_PLACES_API_KEY=

# =========================
# BERT Transaction Categorizer (Phase 12 Step 2)
# =========================
# Path to the trained BERT checkpoint used by the Celery worker for layer-7 categorization.
# If unset, auto-discovery checks:
#   1. backend/ml/bert/artifacts/bert_txn_production/  (promoted production artifact)
#   2. backend/ml/bert/artifacts/<run_id>/best_checkpoint/  (latest training run)
# Example (absolute path recommended for Docker/production):
# BERT_CHECKPOINT_DIR=backend/ml/bert/artifacts/bert_txn_production
